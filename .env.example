# ============================================
# Edge Host Configuration
# ============================================

# Core ERP API endpoint (where data is pushed to)
CORE_API_URL=https://your-erp.manus.space

# Edge Host credentials (obtained from Core ERP > Settings > Edge Hosts)
EDGE_HOST_ID=
EDGE_API_KEY=

# ============================================
# Amazon SP-API Credentials
# ============================================

# Login with Amazon (LWA) credentials
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
SP_API_REFRESH_TOKEN=

# Amazon marketplace (default: US)
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER
SP_API_REGION=us-east-1

# SP-API endpoint (NA: https://sellingpartnerapi-na.amazon.com)
SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# ============================================
# Amazon Advertising API Credentials
# ============================================

ADS_API_CLIENT_ID=
ADS_API_CLIENT_SECRET=
ADS_API_REFRESH_TOKEN=
ADS_API_PROFILE_ID=

# Ads API endpoint (NA: https://advertising-api.amazon.com)
ADS_API_ENDPOINT=https://advertising-api.amazon.com

# ============================================
# Sync Configuration
# ============================================

# Sync mode: realtime | scheduled | manual
SYNC_MODE=scheduled

# Cron schedule for scheduled mode (default: every 6 hours)
SYNC_CRON=0 */6 * * *

# Heartbeat interval in seconds (default: 60)
HEARTBEAT_INTERVAL=60

# Log level: debug | info | warn | error
LOG_LEVEL=info
